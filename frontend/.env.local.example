# Copy this file to .env.local and adjust if your backend runs elsewhere.

# Base URL of the FastAPI backend. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth client ID (public — safe to expose to the browser).
# Must match the client ID configured in app/core/config.py on the backend.
# Leave blank to hide the "Continue with Google" button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Must exactly match an "Authorized redirect URI" in the Google Cloud
# Console for this client ID, and exactly match what the backend's
# /auth/google endpoint receives as redirect_uri.
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
